@model QuanLyQuanAn.Web.Models.Product

<div class="modal-header border-0 pb-0">
    <h5 class="modal-title font-weight-bold text-primary">
        <i class="bi bi-info-circle-fill me-2"></i> CHI TIẾT MÓN ĂN
    </h5>
</div>

<div class="modal-body">
    <div class="row">
        <!-- Cột trái: Hình ảnh và tiêu đề chính -->
        <div class="col-md-4 text-center border-right">
            <div class="product-image-container mb-3">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" class="img-fluid rounded shadow-sm"
                         style="width: 120px; height: 120px; object-fit: cover; border: 3px solid #f8f9fc;" />
                }
                else
                {
                    <div class="mx-auto mb-3 d-flex align-items-center justify-content-center"
                         style="width: 120px; height: 120px; background: #f8f9fc; color: #d1d3e2; border-radius: 15px; font-size: 3rem;">
                        <i class="bi bi-egg-fried"></i>
                    </div>
                }
            </div>
            <h5 class="mb-1 font-weight-bold text-dark">@Model.Name</h5>
            <span class="badge @(Model.IsAvailable ? "bg-success" : "bg-warning") rounded-pill px-3">
                @(Model.IsAvailable ? "Đang phục vụ" : "Tạm ngưng")
            </span>
        </div>

        <!-- Cột phải: Bảng thông tin chi tiết -->
        <div class="col-md-8">
            <table class="table table-sm table-borderless ml-md-2">
                <tr>
                    <td class="text-muted" style="width: 130px;">Danh mục:</td>
                    <td class="font-weight-bold text-dark">@(Model.Category?.Name ?? "Chưa phân loại")</td>
                </tr>
                <tr>
                    <td class="text-muted">Giá bán:</td>
                    <td>
                        <span class="text-primary font-weight-bold" style="font-size: 1.1rem;">
                            @Model.Price.ToString("N0") <small>VNĐ</small>
                        </span>
                    </td>
                </tr>
                <tr>
                    <td class="text-muted">Trạng thái kinh doanh:</td>
                    <td>
                        @if (Model.IsActive)
                        {
                            <span class="text-success"><i class="bi bi-check-circle-fill me-1"></i>Đang kinh doanh</span>
                        }
                        else
                        {
                            <span class="text-danger"><i class="bi bi-x-circle-fill me-1"></i>Ngừng kinh doanh</span>
                        }
                    </td>
                </tr>
                <tr>
                    <td class="text-muted">Mô tả món:</td>
                    <td class="text-dark italic">
                        <small>@(string.IsNullOrEmpty(Model.Description) ? "Không có mô tả cho món này." : Model.Description)</small>
                    </td>
                </tr>
            </table>
        </div>
    </div>
</div>

<div class="modal-footer border-0 pt-0">
    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Đóng</button>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary rounded-pill px-4">
        <i class="bi bi-pencil-square me-1"></i> Chỉnh sửa
    </a>
</div>