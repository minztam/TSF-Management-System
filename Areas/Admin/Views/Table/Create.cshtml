@model QuanLyQuanAn.Web.Areas.Admin.Models.Table.CreateTable

@{
    ViewData["Title"] = "Thêm bàn ăn mới";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Admin/admin-form.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6 mb-4 mt-2">
            <h1 class="h4 mb-0 text-gray-800 font-weight-bold">
                <i class="bi bi-grid-3x3-gap-fill mr-2"></i> THÊM BÀN ĂN MỚI
            </h1>
            <p class="text-muted small">Tạo bàn ăn mới và sắp xếp vào các khu vực của Trung Sơn Food.</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm-custom card-form border-0">
                <div class="card-body p-4">
                    <form id="formCreateTable">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        @* Tên bàn *@
                        <div class="form-group mb-4">
                            <label asp-for="Name" class="font-weight-bold mb-2">Tên bàn</label>
                            <input asp-for="Name" class="form-control form-control-custom" placeholder="Ví dụ: Bàn số 01, Bàn VIP 1..." />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            @* Sức chứa *@
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="Capacity" class="font-weight-bold mb-2">Sức chứa (người)</label>
                                    <input asp-for="Capacity" type="number" class="form-control form-control-custom" value="4" min="1" />
                                    <span asp-validation-for="Capacity" class="text-danger small"></span>
                                </div>
                            </div>
                            @* Khu vực *@
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="AreaName" class="font-weight-bold mb-2">Khu vực</label>
                                    <select asp-for="AreaName" class="form-control form-control-custom">
                                        <option value="Khu vực chung">Khu vực chung</option>
                                        <option value="Sân vườn">Sân vườn</option>
                                        <option value="Phòng VIP">Phòng VIP</option>
                                        <option value="Tầng lầu">Tầng lầu</option>
                                    </select>
                                    <span asp-validation-for="AreaName" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        @* Trạng thái mặc định (Ẩn hoặc Disable vì luôn là Available khi tạo) *@
                        <input type="hidden" asp-for="Status" value="Available" />

                        <hr class="my-4">

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn-back mr-2 text-decoration-none">Hủy bỏ</a>
                            <button type="button" id="btnSubmit" class="btn-save shadow-sm px-4">
                                <i class="bi bi-check-lg mr-1"></i> Lưu bàn ăn
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @* 1. Thư viện SweetAlert2 *@
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @* 2. Thư viện Validation (Thêm trực tiếp vào đây) *@
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.13/jquery.validate.unobtrusive.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#btnSubmit').click(function () {
                const btn = $(this);
                const form = $('#formCreateTable');

                if (!form.valid()) {
                    return false;
                }

                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm mr-2"></span> Đang lưu...');

                $.ajax({
                    url: '@Url.Action("Create", "Table", new { area = "Admin" })',
                    type: 'POST',
                    data: form.serialize(),
                    success: function (res) {
                        if (res.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Thành công',
                                text: res.message,
                                timer: 1500,
                                showConfirmButton: false
                            }).then(() => {
                                window.location.href = '@Url.Action("Index", "Table")';
                            });
                        } else {
                            let errorHtml = '<ul class="text-left text-danger">';
                            if (res.errors) {
                                res.errors.forEach(err => { errorHtml += `<li>${err}</li>`; });
                            } else {
                                errorHtml += `<li>${res.message}</li>`;
                            }
                            errorHtml += '</ul>';

                            Swal.fire({
                                icon: 'error',
                                title: 'Có lỗi xảy ra',
                                html: errorHtml
                            });
                            btn.prop('disabled', false).html('<i class="bi bi-check-lg mr-1"></i> Lưu bàn ăn');
                        }
                    },
                    error: function () {
                        Swal.fire('Lỗi!', 'Không thể kết nối đến máy chủ.', 'error');
                        btn.prop('disabled', false).html('<i class="bi bi-check-lg mr-1"></i> Lưu bàn ăn');
                    }
                });
            });
        });
    </script>
};