@model IEnumerable<QuanLyQuanAn.Web.Models.Table>

@{
    ViewData["Title"] = "Sơ đồ bàn ăn";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/admin-user-index.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <style>
        /* Giữ nguyên các Style bạn đã viết */
        .table-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 1.5rem;
        }

        .table-card {
            background: #ffffff;
            border-radius: 24px;
            border: 1px solid #eef2f6;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

            .table-card:hover {
                transform: translateY(-8px);
                box-shadow: 0 20px 25px -5px rgba(0,0,0,0.05);
            }

            /* Màu sắc động cho border-top */
            .table-card.available {
                border-top: 6px solid #10b981;
            }

            .table-card.occupied {
                border-top: 6px solid #f43f5e;
            }

            .table-card.reserved {
                border-top: 6px solid #f59e0b;
            }

        .time-counter {
            position: absolute;
            top: 15px;
            right: 15px;
            font-size: 0.75rem;
            font-weight: 700;
            padding: 4px 12px;
            border-radius: 50px;
            background: rgba(244, 63, 94, 0.1);
            color: #f43f5e;
            display: flex;
            align-items: center;
        }

        .area-filter {
            background: #f1f5f9;
            padding: 6px;
            border-radius: 16px;
            display: inline-flex;
            gap: 4px;
        }

        .area-item {
            padding: 8px 20px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            transition: all 0.2s;
            color: #64748b;
        }

            .area-item.active {
                background: white;
                color: #4361ee;
                box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            }

        .bg-soft-success {
            background-color: rgba(16, 185, 129, 0.1);
            color: #10b981;
        }

        .bg-soft-danger {
            background-color: rgba(244, 63, 94, 0.1);
            color: #f43f5e;
        }

        .bg-soft-warning {
            background-color: rgba(245, 158, 11, 0.1);
            color: #f59e0b;
        }

        .table-status-icon {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 12px;
        }

        .table-actions {
            background: #f8fafc;
            border-top: 1px solid #f1f5f9;
            padding: 10px;
            display: flex;
            gap: 8px;
        }

        .btn-quick {
            flex: 1;
            padding: 8px;
            border-radius: 10px;
            border: none;
            transition: 0.2s;
            font-size: 0.85rem;
            text-decoration: none;
            text-align: center;
        }

        .btn-quick-edit {
            background: #eff6ff;
            color: #2563eb;
        }

        .btn-quick-del {
            background: #fff1f2;
            color: #e11d48;
        }
    </style>
}

<div class="container-fluid py-3">
    @* --- HEADER --- *@
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between mb-4 gap-3">
        <div>
            <h2 class="h4 font-weight-bold text-dark mb-1">
                <i class="bi bi-grid-3x3-gap-fill me-2 text-primary"></i>Sơ đồ bàn ăn
            </h2>
            <div class="area-filter mt-2">
                <div class="area-item active" data-filter="all">Tất cả</div>
                @foreach (var area in Model.Select(x => x.AreaName).Distinct())
                {
                    <div class="area-item" data-filter="@area">@area</div>
                }
            </div>
        </div>

        <a asp-action="Create" class="btn btn-primary btn-lg px-4 py-2 shadow rounded-pill font-weight-bold">
            <i class="bi bi-plus-circle-fill me-2"></i>Thêm bàn mới
        </a>
    </div>

    @* --- CHÚ THÍCH --- *@
    <div class="d-flex flex-wrap gap-4 mb-4 justify-content-center border-bottom pb-4">
        <div class="small fw-bold"><i class="bi bi-circle-fill text-success me-2"></i>Sẵn sàng</div>
        <div class="small fw-bold"><i class="bi bi-circle-fill text-danger me-2"></i>Đang phục vụ</div>
        <div class="small fw-bold"><i class="bi bi-circle-fill text-warning me-2"></i>Đặt trước</div>
    </div>

    @* --- LƯỚI DANH SÁCH BÀN DÙNG DỮ LIỆU THẬT --- *@
    <div class="table-grid">
        @foreach (var item in Model)
        {
            <div class="table-card @item.Status.ToLower() shadow-sm" data-area="@item.AreaName">

                @* Hiển thị thời gian nếu bàn đang dùng *@
                @if (item.Status == "Occupied")
                {
                    <div class="time-counter">
                        <i class="bi bi-clock-history me-1"></i> @item.SittingTime
                    </div>
                }

            <div class="p-4 text-center">
                @* Icon thay đổi theo trạng thái *@
                <div class="table-status-icon mx-auto
                        @(item.Status == "Available" ? "bg-soft-success" :
                                               item.Status == "Occupied" ? "bg-soft-danger" : "bg-soft-warning")">

                    <i class="bi @(item.Status == "Available" ? "bi-check-lg" :
                                                             item.Status == "Occupied" ? "bi-people-fill" : "bi-bookmark-star-fill") fs-5"></i>
                </div>

                    <h5 class="fw-bold text-dark mb-1">@item.Name</h5>
                    <p class="text-muted small mb-2"><i class="bi bi-geo-alt me-1"></i>@item.AreaName</p>
                    <span class="badge bg-light text-dark border px-3">@item.Capacity người</span>
                </div>

                <div class="table-actions">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-quick btn-quick-edit">
                        <i class="bi bi-pencil-square me-1"></i>Sửa
                    </a>
                    <button class="btn-quick btn-quick-del btn-delete-ajax" data-id="@item.Id" data-name="@item.Name">
                        <i class="bi bi-trash3 me-1"></i>Xóa
                    </button>
                </div>
            </div>
                }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            // Lọc theo khu vực (Client-side)
            $('.area-item').click(function() {
                const filter = $(this).data('filter');
                $('.area-item').removeClass('active');
                $(this).addClass('active');

                if (filter === 'all') {
                    $('.table-card').fadeIn();
                } else {
                    $('.table-card').hide();
                    $(`.table-card[data-area="${filter}"]`).fadeIn();
                }
            });

            // Xử lý xóa bằng AJAX
            $('.btn-delete-ajax').click(function () {
                const id = $(this).data('id');
                const name = $(this).data('name');

                Swal.fire({
                    title: `Xóa ${name}?`,
                    text: "Dữ liệu bàn này sẽ mất vĩnh viễn!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#f43f5e',
                    confirmButtonText: 'Đồng ý xóa',
                    cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '@Url.Action("Delete", "Table")',
                            type: 'POST',
                            data: { id: id },
                            success: function (res) {
                                if (res.success) {
                                    Swal.fire({
                                    icon: 'success',
                                    title: 'Đã xóa!',
                                    text: res.message,
                                    timer: 1500,
                                    showConfirmButton: false
                                    }).then(() => {
                                        location.reload();
                                    });
                                } 
                                else {
                                    Swal.fire('Thất bại', res.message, 'error');
                                }
                            },
                            error: function () {
                                Swal.fire('Lỗi!', 'Không thể kết nối đến máy chủ.', 'error');
                            }
                        });
                    }
                });
            });
        });
    </script>
}