@model IEnumerable<QuanLyQuanAn.Web.Models.Ingredient>
@{
    ViewData["Title"] = "Quản lý kho hàng";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <style>
        .shadow-soft {
            box-shadow: 0 0.75rem 1.5rem rgba(18, 38, 63, 0.03) !important;
        }

        .avatar-circle {
            width: 45px;
            height: 45px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
            font-weight: bold;
        }

        .badge-custom {
            padding: 0.5em 1em;
            border-radius: 50rem;
            font-weight: 600;
            font-size: 0.75rem;
            display: inline-flex;
            align-items: center;
        }

        /* Màu sắc trạng thái kho */
        .stock-out {
            background-color: #fff1f2 !important;
        }
        /* Nền đỏ nhạt cho dòng hết hàng */
        .status-danger {
            background: #fee2e2;
            color: #dc2626;
        }
        /* Đã hết hàng */
        .status-warning {
            background: #fef3c7;
            color: #d97706;
        }
        /* Sắp hết hàng */
        .status-success {
            background: #ecfdf5;
            color: #10b981;
        }
        /* Còn hàng */

        .btn-action {
            width: 35px;
            height: 35px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            transition: all 0.2s;
            border: none;
        }

            .btn-action.edit {
                background: #fff7ed;
                color: #f59e0b;
            }

            .btn-action.delete {
                background: #fff1f2;
                color: #f43f5e;
            }

            .btn-action.import {
                background: #eef2ff;
                color: #4361ee;
            }

            .btn-action:hover {
                transform: translateY(-2px);
                filter: brightness(0.95);
            }

        .filter-pill {
            cursor: pointer;
            transition: all 0.3s;
            border: 1px solid #e2e8f0;
        }

            .filter-pill.active {
                background: #4361ee;
                color: white;
                border-color: #4361ee;
            }
    </style>
}

<div class="container-fluid py-3">
    @* --- Header --- *@
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h2 class="h4 font-weight-bold text-dark mb-1"><i class="bi bi-box-seam me-2 text-primary"></i>Quản lý kho nguyên liệu</h2>
            <p class="text-muted small mb-0">Hệ thống quản trị nội bộ Trung Sơn Food v1.0</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary btn-lg px-4 py-2 shadow rounded-pill font-weight-bold"
                    data-bs-toggle="modal" data-bs-target="#createIngredientModal"
                    style="font-size: 0.9rem;">
                <i class="bi bi-plus-circle-fill me-2"></i>Thêm nguyên liệu
            </button>
        </div>
    </div>

    @* --- Statistics --- *@
    <div class="row mb-4 g-3">
        <div class="col-md-3">
            <div class="card shadow-soft border-0 p-3 h-100" style="border-radius: 15px;">
                <div class="d-flex align-items-center">
                    <div class="avatar-circle me-3" style="background: #eef2ff; color: #4361ee;">
                        <i class="bi bi-list-ul fs-5"></i>
                    </div>
                    <div>
                        <div class="text-muted small font-weight-bold text-uppercase">Tổng mặt hàng</div>
                        <div class="h4 mb-0 font-weight-bold text-dark">@Model.Count()</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-soft border-0 p-3 h-100" style="border-radius: 15px; border-left: 4px solid #ef4444 !important;">
                <div class="d-flex align-items-center">
                    <div class="avatar-circle me-3" style="background: #fee2e2; color: #ef4444;">
                        <i class="bi bi-x-octagon-fill fs-5"></i>
                    </div>
                    <div>
                        <div class="text-muted small font-weight-bold text-uppercase">Đã hết hàng</div>
                        <div class="h4 mb-0 font-weight-bold text-danger">1</div> @* Số giả lập *@
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-soft border-0 p-3 h-100" style="border-radius: 15px; border-left: 4px solid #f59e0b !important;">
                <div class="d-flex align-items-center">
                    <div class="avatar-circle me-3" style="background: #fff7ed; color: #f59e0b;">
                        <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                    </div>
                    <div>
                        <div class="text-muted small font-weight-bold text-uppercase">Sắp hết hàng</div>
                        <div class="h4 mb-0 font-weight-bold" style="color: #d97706;">2</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-soft border-0 p-3 h-100" style="border-radius: 15px;">
                <div class="d-flex align-items-center">
                    <div class="avatar-circle me-3" style="background: #ecfdf5; color: #10b981;">
                        <i class="bi bi-check-all fs-5"></i>
                    </div>
                    <div>
                        <div class="text-muted small font-weight-bold text-uppercase">Đang sử dụng</div>
                        <div class="h4 mb-0 font-weight-bold text-success">@Model.Count(x => x.IsActive)</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* --- Filter & Search --- *@
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="d-flex gap-2">
            <span class="badge rounded-pill filter-pill px-3 py-2 active">Tất cả</span>
            <span class="badge rounded-pill filter-pill px-3 py-2 text-dark">Hết hàng (1)</span>
            <span class="badge rounded-pill filter-pill px-3 py-2 text-dark">Sắp hết (2)</span>
        </div>
        <div class="search-box">
            <input type="text" class="form-control form-control-sm rounded-pill px-3" placeholder="Tìm nguyên liệu...">
        </div>
    </div>

    @* --- Table Content --- *@
    <div class="card shadow-soft border-0 overflow-hidden" style="border-radius: 20px !important;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table mb-0 align-middle">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Nguyên liệu</th>
                            <th class="text-center">Số lượng tồn</th>
                            <th>ĐVT</th>
                            <th>Trạng thái kho</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            @* 1. Xác định class dòng dựa trên số lượng thực tế *@
                            string rowClass = item.Quantity <= 0 ? "stock-out" : "";

                            <tr class="@rowClass">
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        @* Avatar chữ cái đầu *@
                                        <div class="avatar-circle me-3 shadow-sm" style="background: white; color: #64748b; width: 40px; height: 40px; border: 1px solid #f1f5f9;">
                                            @(string.IsNullOrEmpty(item.Name) ? "?" : item.Name.Substring(0, 1).ToUpper())
                                        </div>
                                        <div>
                                            <div class="font-weight-bold text-dark">@item.Name</div>
                                            <small class="text-muted">ID: @item.Id.ToString().Substring(0, 8)</small>
                                        </div>
                                    </div>
                                </td>

                                @* 2. Hiển thị số lượng thực thực tế *@
                                <td class="text-center">
                                    <span class="h6 mb-0 fw-bold @(item.Quantity <= 0 ? "text-danger" : (item.Quantity < 10 ? "text-warning" : "text-dark"))">
                                        @item.Quantity
                                    </span>
                                </td>

                                <td>
                                    <span class="badge bg-light text-dark px-3 py-2 rounded-pill">@item.Unit</span>
                                </td>

                                @* 3. Logic hiển thị Badge trạng thái *@
                                <td>
                                    @if (item.Quantity <= 0)
                                    {
                                        <span class="badge-custom status-danger"><i class="bi bi-x-circle-fill me-1"></i> Hết hàng</span>
                                    }
                                    else if (item.Quantity < 10)
                                    {
                                        <span class="badge-custom status-warning"><i class="bi bi-exclamation-triangle-fill me-1"></i> Sắp hết</span>
                                    }
                                    else
                                    {
                                        <span class="badge-custom status-success"><i class="bi bi-check-circle-fill me-1"></i> An toàn</span>
                                    }
                                </td>

                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-2">
                                        @* Nhập kho nhanh *@
                                        <button class="btn-action import shadow-sm"
                                                title="Nhập kho nhanh"
                                                onclick="openImportModal('@item.Id', '@item.Name', '@item.Unit')">
                                            <i class="bi bi-plus-lg"></i>
                                        </button>

                                        @* Chỉnh sửa *@
                                        <button class="btn-action edit shadow-sm"
                                                title="Chỉnh sửa"
                                                onclick="openEditModal('@item.Id')">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>

                                        @* Xóa/Ngưng sử dụng *@
                                        <button class="btn-action delete btn-delete-ingredient shadow-sm"
                                                data-name="@item.Name"
                                                data-id="@item.Id">
                                            <i class="bi bi-trash3-fill"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@* --- MODAL THÊM MỚI --- *@
<div class="modal fade" id="createIngredientModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0" style="border-radius: 20px;">
            <div class="modal-header border-0 bg-light" style="border-radius: 20px 20px 0 0;">
                <h5 class="modal-title fw-bold text-dark">
                    <i class="bi bi-plus-circle me-2 text-primary"></i>Thêm nguyên liệu mới
                </h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>

            @* Gọi Partial View ở đây *@
            <partial name="_CreatePartial" model="new QuanLyQuanAn.Web.Models.Ingredient()" />

        </div>
    </div>
</div>

@* --- MODAL CHỈNH SỬA ---*@
<div class="modal fade" id="editIngredientModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0" style="border-radius: 20px;">
            <div class="modal-header border-0 bg-light" style="border-radius: 20px 20px 0 0;">
                <h5 class="modal-title fw-bold"><i class="bi bi-pencil-square me-2 text-warning"></i>Chỉnh sửa nguyên liệu</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <partial name="_EditPartial" model="new QuanLyQuanAn.Web.Models.Ingredient()" />
        </div>
    </div>
</div>

@* --- MODAL NHẬP KHO NHANH --- *@
<div class="modal fade" id="importStockModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0" style="border-radius: 20px;">
            <div class="modal-body p-4 text-center">
                <input type="hidden" id="importItemId" />
                <div class="avatar-circle mx-auto mb-3" style="background: #eef2ff; color: #4361ee; width: 60px; height: 60px;">
                    <i class="bi bi-box-arrow-in-down fs-3"></i>
                </div>
                <h6 class="fw-bold mb-1">Nhập thêm hàng</h6>
                <p id="importItemName" class="text-primary small mb-3 fw-bold"></p>
                <div class="input-group mb-3 shadow-sm rounded-pill overflow-hidden">
                    <input type="number" id="additionalQty" class="form-control border-0 bg-light text-center" placeholder="0.00">
                    <span class="input-group-text border-0 bg-light px-3" id="importItemUnit"></span>
                </div>
                <div class="d-grid gap-2">
                    <button type="button" class="btn btn-primary rounded-pill py-2 btn-save-stock">Xác nhận nhập</button>
                    <button type="button" class="btn btn-link btn-sm text-muted text-decoration-none" data-bs-dismiss="modal">Bỏ qua</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <partial name="_ValidationScriptsPartial" />

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <partial name="_ValidationScriptsPartial" />

    <script>
        // 1. Khởi tạo Toast cấu hình chung
        const Toast = Swal.mixin({
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 3000,
            timerProgressBar: true
        });

        // 2. Hàm mở Modal Chỉnh sửa (Phải để ngoài document.ready)
        function openEditModal(id) {
            $.get('/Admin/Warehouse/GetIngredient', { id: id }, function (data) {
                $('#editId').val(data.id);
                $('#editName').val(data.name);
                $('#editUnit').val(data.unit);
                $('#editQuantity').val(data.quantity);
                $('#editIngredientModal').modal('show');
            }).fail(function() {
                Toast.fire({ icon: 'error', title: 'Không thể lấy dữ liệu!' });
            });
        }

        // 3. Hàm mở Modal Nhập kho
        function openImportModal(id, name, unit) {
            $('#importItemId').val(id);
            $('#importItemName').text(name);
            $('#importItemUnit').text(unit);
            $('#additionalQty').val('');
            $('#importStockModal').modal('show');
        }

        $(document).ready(function () {
            // 4. Hiển thị thông báo từ TempData (Dùng Toast cho đẹp)
            var successMsg = '@TempData["Success"]';
            var errorMsg = '@TempData["Error"]';

            if (successMsg) {
                Toast.fire({ icon: 'success', title: successMsg, background: '#ecfdf5', iconColor: '#10b981' });
            }
            if (errorMsg) {
                Toast.fire({ icon: 'error', title: errorMsg, background: '#fff1f2', iconColor: '#f43f5e' });
            }

            // 5. Xử lý Xóa bằng AJAX
            $('.btn-delete-ingredient').click(function () {
                const id = $(this).data('id');
                const name = $(this).data('name');

                Swal.fire({
                    title: 'Xác nhận xóa?',
                    html: `Ngưng sử dụng nguyên liệu <b>${name}</b>?`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#f43f5e',
                    confirmButtonText: 'Đồng ý',
                    cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.post('/Admin/Warehouse/Delete', { id: id }, function(response) {
                            if(response.success) {
                                location.reload();
                            } else {
                                Swal.fire('Lỗi', response.message, 'error');
                            }
                        });
                    }
                });
            });

            // 6. Xử lý lưu Nhập kho nhanh
            $('.btn-save-stock').click(function() {
                const id = $('#importItemId').val();
                const qty = $('#additionalQty').val();
                if(!qty || qty <= 0) return Toast.fire({ icon: 'warning', title: 'Nhập số lượng > 0' });

                $.post('/Admin/Warehouse/ImportStock', { id: id, additionalQty: qty }, function(response) {
                    if(response.success) {
                        location.reload();
                    } else {
                        Toast.fire({ icon: 'error', title: response.message });
                    }
                });
            });
        });
    </script>
    <script>
            $(document).ready(function () {
            // 1. Cấu hình mặc định cho Toast (Thông báo nhỏ gọn)
            const Toast = Swal.mixin({
                toast: true,
                position: 'top-end', // Hiển thị ở góc trên bên phải
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true,
                didOpen: (toast) => {
                    toast.addEventListener('mouseenter', Swal.stopTimer)
                    toast.addEventListener('mouseleave', Swal.resumeTimer)
                }
            });

            // 2. Lấy dữ liệu từ TempData
            var successMsg = '@TempData["Success"]';
            var errorMsg = '@TempData["Error"]';

            // 3. Hiển thị thông báo Thành công
            if (successMsg && successMsg !== '') {
                Toast.fire({
                    icon: 'success',
                    title: successMsg,
                    // Bạn có thể tùy chỉnh màu sắc cho hợp với Trung Sơn Food
                    background: '#ecfdf5',
                    iconColor: '#10b981'
                });
            }

            // 4. Hiển thị thông báo Lỗi
            if (errorMsg && errorMsg !== '') {
                Toast.fire({
                    icon: 'error',
                    title: errorMsg,
                    background: '#fff1f2',
                    iconColor: '#f43f5e'
                });
            }
        });
    </script>
}