@model QuanLyQuanAn.Web.Models.Ingredient

<form asp-action="Edit" asp-controller="Warehouse" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" id="editId" />

    <div class="modal-body p-4">
        <div class="row g-3">
            <div class="col-md-8">
                <label class="form-label small fw-bold text-uppercase">Tên nguyên liệu</label>
                <input asp-for="Name" id="editName" class="form-control border-0 bg-light py-2 shadow-none" required>
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label class="form-label small fw-bold text-uppercase">Số lượng hiện tại</label>
                <input asp-for="Quantity" id="editQuantity" type="number" step="0.01" class="form-control border-0 bg-light py-2 shadow-none">
            </div>
            <div class="col-12">
                <label class="form-label small fw-bold text-uppercase">Đơn vị tính</label>
                <select asp-for="Unit" id="editUnit" class="form-select border-0 bg-light py-2 shadow-none">
                    <option value="Kg">Kg</option>
                    <option value="Gói">Gói</option>
                    <option value="Chai">Chai</option>
                    <option value="Lít">Lít</option>
                </select>
            </div>
        </div>
    </div>
    <div class="modal-footer border-0">
        <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
        <button type="submit" class="btn btn-warning text-white rounded-pill px-4 shadow-sm">
            <i class="bi bi-pencil-square me-2"></i>Cập nhật
        </button>
    </div>
</form>